# API 프록시(서버). 비우면 코드 기본값(https://quizai-be.onrender.com) 사용
API_SERVER_URL=

# 프록시 목 응답 (기본 사용 안 함). 로컬에서 백엔드 없이 UI만 볼 때만 true
ENABLE_PROXY_MOCK_FALLBACK=false

# 클라이언트가 호출하는 API 베이스. 비우면 /api/proxy (권장)
NEXT_PUBLIC_API_URL=

# 퀴즈 WebSocket 기본 호스트(폴백). 수강생은 POST /sessions/join 응답의 ws_url을 우선 사용합니다.
# 연결 실패 시 Render에서 WebSocket Origin(예: https://quizai-fe.vercel.app) 허용 여부를 확인하세요.
NEXT_PUBLIC_WS_URL=
